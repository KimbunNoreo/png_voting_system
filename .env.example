DJANGO_SECRET_KEY=change-me
SECUREVOTE_ENV=development
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=securevote
DB_HOST=localhost
DB_PORT=5432
DB_USER=securevote
DB_PASSWORD=securevote
DB_SSLMODE=require

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

NID_BASE_URL=https://nid.example.gov.pg
NID_API_KEY=replace-me
NID_MTLS_CERT_PATH=/run/secrets/nid-client.crt
